            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let Source = List.Dates(#date(2023,1,1), Duration.Days(#date(2027,12,31)-#date(2023,1,1))+1, #duration(1,0,0,0)), T = Table.FromList(Source, Splitter.SplitByNothing(), {\"Date\"}), T2 = Table.AddColumn(T,\"Year\", each Date.Year([Date]), Int64.Type), T3 = Table.AddColumn(T2,\"Quarter\", each Text.From(Date.Year([Date])) & \"-Q\" & Text.From(Date.QuarterOfYear([Date])) ), T4 = Table.AddColumn(T3,\"Month\", each Date.Month([Date]), Int64.Type), T5 = Table.AddColumn(T4,\"MonthName\", each Date.MonthName([Date])) in T5"
            }
          }
        ]
