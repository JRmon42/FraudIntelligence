      {
        "name": "_Measures",
        "columns": [
          {
            "name": "_dummy",
            "dataType": "int64",
            "sourceColumn": "_dummy",
            "isHidden": true,
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "_Measures",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let Source = #table({\"_dummy\"},{{0}}) in Source"
            }
          }
        ],
        "measures": [
          {
            "name": "Total Tx Value (€)",
            "expression": "SUM(Fact_Tx[TxValueEur])",
            "formatString": "\"€\"#,0",
            "description": "Sum of EUR-converted booked transaction value across the selected period and country filter."
          },
          {
            "name": "Total Tx Count",
            "expression": "SUM(Fact_Tx[TxCount])",
            "formatString": "#,0",
            "description": "Sum of authorised payment transactions (excludes pre-auth and reversals) per Fact_Tx grain."
          },
          {
            "name": "Decline Rate %",
            "expression": "DIVIDE(SUM(Fact_Tx[DeclineCount]), SUM(Fact_Tx[TxCount]))",
            "formatString": "0.00%",
            "description": "Declines divided by total decisions — KPI tracked vs the 1.1% target."
          },
          {
            "name": "Fraud Loss (€)",
            "expression": "SUM(Fact_Tx[LossValueEur])",
            "formatString": "\"€\"#,0",
            "description": "Confirmed fraud loss amount borne by the PSP (sourced from Cases mart)."
          },
          {
            "name": "Fraud Rate (bps)",
            "expression": "DIVIDE(SUM(Fact_Tx[FraudValueEur]), SUM(Fact_Tx[TxValueEur])) * 10000",
            "formatString": "0.00",
            "description": "Fraud rate in basis points (€ fraud / € authorised × 10 000) — EBA Annex C convention."
          },
          {
            "name": "Scoring p99 (ms)",
            "expression": "AVERAGE(Fact_Latency[P99Ms])",
            "formatString": "0.0",
            "description": "Average daily p99 scoring latency across model versions — target < 18 ms."
          },
          {
            "name": "PSD2 Exemption Coverage %",
            "expression": "DIVIDE(CALCULATE(SUM(Fact_Exemption[TxCount]), Fact_Exemption[ExemptionCode] <> \"sca_applied\"), SUM(Fact_Exemption[TxCount]))",
            "formatString": "0.00%",
            "description": "Share of in-scope transactions that successfully used an SCA exemption (target > 70%)."
          },
          {
            "name": "Total Fraud Count",
            "expression": "SUM(Fact_Eba[FraudCount])",
            "formatString": "#,0",
            "description": "Confirmed fraudulent transactions for EBA Annex B."
          },
          {
            "name": "EBA Annex C Fraud Rate (bps)",
            "expression": "DIVIDE(SUM(Fact_Eba[FraudValueEur]), SUM(Fact_Eba[TxValueEur])) * 10000",
            "formatString": "0.00",
            "description": "Annex C basis-points fraud rate computed on the EBA aggregates (matches submitted XLSX)."
          },
          {
            "name": "Loss Borne by PSP (€)",
            "expression": "CALCULATE(SUM(Fact_Eba[LossValueEur]), Fact_Eba[LossBearer] = \"psp\")",
            "formatString": "\"€\"#,0",
            "description": "Loss amount allocated to the PSP per EBA Annex D."
          },
          {
            "name": "Loss Borne by Payer (€)",
            "expression": "CALCULATE(SUM(Fact_Eba[LossValueEur]), Fact_Eba[LossBearer] = \"payer\")",
            "formatString": "\"€\"#,0",
            "description": "Loss amount allocated to the payer per EBA Annex D."
          },
          {
            "name": "Open Cases",
            "expression": "COUNTROWS(FILTER(Fact_Eba, Fact_Eba[FraudCount] > 0))",
            "formatString": "#,0",
            "description": "Distinct EBA aggregate rows that contributed at least one fraud — proxy for case workload."
          },
          {
            "name": "Model Drift Index",
            "expression": "VAR p99_today = AVERAGE(Fact_Latency[P99Ms]) VAR p99_baseline = CALCULATE(AVERAGE(Fact_Latency[P99Ms]), DATEADD(Dim_Date[Date], -30, DAY)) RETURN DIVIDE(p99_today - p99_baseline, p99_baseline)",
            "formatString": "0.00%",
            "description": "Relative drift in p99 latency vs the 30-day-prior baseline — alert at > 25%."
          }
        ]
      }
    ],
