# --- Service ---
SCORING_API_PORT=8080
SCORING_API_LOG_LEVEL=INFO
SCORING_API_ENV=dev

# --- Cosmos DB ---
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE=fraudintel
COSMOS_CARDS_CONTAINER=cards
COSMOS_MERCHANTS_CONTAINER=merchants
# Optional: when unset, DefaultAzureCredential is used (recommended).
COSMOS_KEY=

# --- Redis (real-time aggregates) ---
REDIS_URL=redis://localhost:6379/0
# Set to "1" to use in-memory fakeredis (tests / local dev without Redis)
REDIS_FAKE=0

# --- Event Hubs ---
EVENTHUB_FQDN=your-eh-namespace.servicebus.windows.net
EVENTHUB_DECISIONS=decision.events
# Optional connection string fallback. Empty = use DefaultAzureCredential.
EVENTHUB_CONN_STR=

# --- ONNX model ---
MODEL_PATH=ml/artifacts/ensemble.onnx
MODEL_VERSION=v0.0.0-stub

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=scoring-api
OTEL_RESOURCE_ATTRIBUTES=service.namespace=fraudintel,deployment.environment=dev

# --- Azure Key Vault (optional) ---
AZURE_KEY_VAULT_URL=
