# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01

# --- Cosmos DB (cases container, SQL API) ---
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=fraudintel
COSMOS_CASES_CONTAINER=cases

# --- Cosmos DB Gremlin (graph) ---
GREMLIN_ENDPOINT=wss://your-cosmos.gremlin.cosmos.azure.com:443/
GREMLIN_DATABASE=fraudintel
GREMLIN_GRAPH=fraud-graph
GREMLIN_KEY=

# --- Service ---
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8080
LOG_LEVEL=INFO

# --- Behaviour ---
MOCK_LLM=false
MOCK_COSMOS=true
REFLECTION_BUDGET=2

# --- OTEL ---
OTEL_SERVICE_NAME=fi-agentic-orchestrator
OTEL_EXPORTER_OTLP_ENDPOINT=
